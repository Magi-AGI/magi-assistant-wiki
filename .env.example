# Wiki Assistant agent — environment template.
# Copy to .env (gitignored) and fill in real values for local dev.

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Service key (use Magi billing for V1; rotate to SNET-billed key before launch).
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── hyperon-wiki MCP subprocess ───────────────────────────────────────────────
# Auth — pick ONE method.
# Service account (recommended for production):
MCP_API_KEY=
MCP_ROLE=user
# OR Decko user/password (for local-dev / personal account):
# MCP_USERNAME=
# MCP_PASSWORD=

# Optional: override the wiki API base (default https://wiki.hyperon.dev/api/mcp)
# DECKO_API_BASE_URL=https://wiki.hyperon.dev/api/mcp

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8766

# Default Anthropic model. Plan B-3 locks this to claude-sonnet-4-6.
# Haiku is rejected for V1 (underperforms on tool-orchestration).
DEFAULT_MODEL=claude-sonnet-4-6

# ── Limits (plan B-5 + B-7) ───────────────────────────────────────────────────
# Conversation input cap, signed-in users
MAX_CONVERSATION_TOKENS_AUTH=16000
# Conversation input cap, anonymous users
MAX_CONVERSATION_TOKENS_ANON=6000
# Hard wall-clock budget per agent call (plan I-5)
AGENT_TIMEOUT_MS=30000

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Log level for the structured JSON logger
LOG_LEVEL=info
