# Wiki Assistant agent — environment template.
# Copy to .env (gitignored) and fill in real values for local dev.

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Service key (use Magi billing for V1; rotate to SNET-billed key before launch).
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── hyperon-wiki MCP (HTTP transport) ─────────────────────────────────────────
# The agent connects to the running hyperon-mcp-http.service over HTTP. The
# SDK fetches a JWT from /api/mcp/auth on demand using MCP_USERNAME/PASSWORD.
# Override MCP_API_KEY with a pre-issued JWT to skip the per-process auth fetch.

# Where the MCP server listens (local default).
# MCP_URL=http://127.0.0.1:3002/mcp
# MCP_AUTH_URL=http://127.0.0.1:3000/api/mcp/auth

# Service-account credentials (preferred). Email + password of a Decko user
# with the desired read role.
MCP_USERNAME=
MCP_PASSWORD=
MCP_ROLE=user

# Pre-issued JWT — short-circuits the username/password auth fetch.
# MCP_API_KEY=

# Decko API base. Only used as a fallback default; MCP_URL/MCP_AUTH_URL above
# are the load-bearing endpoints in V1.
# DECKO_API_BASE_URL=https://wiki.hyperon.dev/api/mcp

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8766

# Default Anthropic model. Plan B-3 locks this to claude-sonnet-4-6.
# Haiku is rejected for V1 (underperforms on tool-orchestration).
DEFAULT_MODEL=claude-sonnet-4-6

# ── Limits (plan B-5 + B-7) ───────────────────────────────────────────────────
# Conversation input cap, signed-in users
MAX_CONVERSATION_TOKENS_AUTH=16000
# Conversation input cap, anonymous users
MAX_CONVERSATION_TOKENS_ANON=6000
# Hard wall-clock budget per agent call (plan I-5)
AGENT_TIMEOUT_MS=30000

# ── Telemetry ─────────────────────────────────────────────────────────────────
# Log level for the structured JSON logger
LOG_LEVEL=info
